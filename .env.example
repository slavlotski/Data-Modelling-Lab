# PostgreSQL
POSTGRES_USER=dml_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Application database (stores challenge metadata)
APP_DB_NAME=dml_app

# Sandbox database (user's playground — isolated)
SANDBOX_DB_NAME=dml_sandbox

# Server
SERVER_PORT=3001
NODE_ENV=development

# Client
VITE_API_URL=http://localhost:3001/api
CLIENT_URL=http://localhost:5173

# Content
CONTENT_DIR=../content
